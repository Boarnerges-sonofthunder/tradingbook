{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-remove",
    "fs:allow-applocaldata-write-recursive",
    "fs:scope-appdata-recursive",
    "fs:scope-applocaldata-recursive",
    "log:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*" },
        { "url": "https://*:*" },
        { "url": "http://*" },
        { "url": "https://*" }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "python",
          "cmd": "python",
          "args": true
        },
        {
          "name": "python3",
          "cmd": "python3",
          "args": true
        },
        {
          "name": "py",
          "cmd": "py",
          "args": true
        },
        {
          "name": "python313_local",
          "cmd": "$LOCALDATA/Programs/Python/Python313/python.exe",
          "args": true
        },
        {
          "name": "python312_local",
          "cmd": "$LOCALDATA/Programs/Python/Python312/python.exe",
          "args": true
        },
        {
          "name": "python311_local",
          "cmd": "$LOCALDATA/Programs/Python/Python311/python.exe",
          "args": true
        },
        {
          "name": "python310_local",
          "cmd": "$LOCALDATA/Programs/Python/Python310/python.exe",
          "args": true
        },
        {
          "name": "python39_local",
          "cmd": "$LOCALDATA/Programs/Python/Python39/python.exe",
          "args": true
        },
        {
          "name": "python38_local",
          "cmd": "$LOCALDATA/Programs/Python/Python38/python.exe",
          "args": true
        },
        {
          "name": "python_windowsapps",
          "cmd": "$LOCALDATA/Microsoft/WindowsApps/python.exe",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "python",
          "cmd": "python",
          "args": true
        },
        {
          "name": "python3",
          "cmd": "python3",
          "args": true
        },
        {
          "name": "py",
          "cmd": "py",
          "args": true
        },
        {
          "name": "python313_local",
          "cmd": "$LOCALDATA/Programs/Python/Python313/python.exe",
          "args": true
        },
        {
          "name": "python312_local",
          "cmd": "$LOCALDATA/Programs/Python/Python312/python.exe",
          "args": true
        },
        {
          "name": "python311_local",
          "cmd": "$LOCALDATA/Programs/Python/Python311/python.exe",
          "args": true
        },
        {
          "name": "python310_local",
          "cmd": "$LOCALDATA/Programs/Python/Python310/python.exe",
          "args": true
        },
        {
          "name": "python39_local",
          "cmd": "$LOCALDATA/Programs/Python/Python39/python.exe",
          "args": true
        },
        {
          "name": "python38_local",
          "cmd": "$LOCALDATA/Programs/Python/Python38/python.exe",
          "args": true
        },
        {
          "name": "python_windowsapps",
          "cmd": "$LOCALDATA/Microsoft/WindowsApps/python.exe",
          "args": true
        }
      ]
    }
  ]
}
