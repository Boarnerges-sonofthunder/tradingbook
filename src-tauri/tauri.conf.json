{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TradingBook",
  "version": "0.1.16",
  "identifier": "com.tradingbook.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TradingBook",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "resources": {
      "resources/mt5_bridge.py": "mt5_bridge.py"
    },
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDMzM0RkQ2RjAwMEUwNzEKUldSeDRBRHcxazh6bks3RGJRR1RnZmFoQ3g3REx1MVA0b3p5RFRwWnZaaVJPK3RKTUQzbTdEenEK",
      "endpoints": [
        "https://github.com/Boarnerges-sonofthunder/tradingbook/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
